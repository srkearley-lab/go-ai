# ── Analytics ─────────────────────────────────────────────────────────────────
# Google Analytics 4 — Measurement ID (G-XXXXXXXXXX)
VITE_GA_ID=

# Google Tag Manager — Container ID (GTM-XXXXXXX)
VITE_GTM_ID=

# Meta / Facebook Pixel ID
VITE_META_PIXEL_ID=

# ── Booking ────────────────────────────────────────────────────────────────────
# Calendly embed URL (https://calendly.com/your-username/consultation)
VITE_CALENDLY_URL=

# ── Email / Contact form ───────────────────────────────────────────────────────
# Email address for contact form submissions
VITE_CONTACT_EMAIL=

# Resend API key (https://resend.com) — for transactional emails
RESEND_API_KEY=

# ── Payments (Stripe) ─────────────────────────────────────────────────────────
# Stripe publishable key (pk_live_... or pk_test_...)
VITE_STRIPE_PUBLISHABLE_KEY=

# Stripe secret key — NEVER expose in frontend code, server-side only
STRIPE_SECRET_KEY=

# Stripe webhook signing secret
STRIPE_WEBHOOK_SECRET=

# ── Database (Supabase) ───────────────────────────────────────────────────────
# Supabase project URL (https://xxxx.supabase.co)
VITE_SUPABASE_URL=

# Supabase anon/public key
VITE_SUPABASE_ANON_KEY=

# ── AI APIs ───────────────────────────────────────────────────────────────────
# OpenAI API key — server-side only
OPENAI_API_KEY=

# Anthropic API key — server-side only
ANTHROPIC_API_KEY=

# ── Notes ─────────────────────────────────────────────────────────────────────
# VITE_ prefix = safe to expose in browser bundle
# Keys WITHOUT VITE_ prefix = server-side only, never in frontend code
# Copy this file to .env and fill in your values
# Never commit .env to git
